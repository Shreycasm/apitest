{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Razorpay Error Response",
    "description": "Schema for all error responses from Razorpay",
    "type": "object",
    "required": [
        "error"
    ],
    "properties": {
        "error": {
            "type": "object",
            "required": [
                "code",
                "description"
            ],
            "properties": {
                "code": {
                    "type": "string",
                    "enum": [
                        "BAD_REQUEST_ERROR",
                        "SERVER_ERROR",
                        "GATEWAY_ERROR"
                    ],
                    "description": "Error code category"
                },
                "description": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Human readable error message"
                },
                "source": {
                    "type": "string",
                    "description": "Error source"
                },
                "step": {
                    "type": "string",
                    "description": "Step where error occurred"
                },
                "reason": {
                    "type": "string",
                    "description": "Specific reason"
                },
                "metadata": {
                    "type": "object",
                    "description": "Additional error context"
                },
                "field": {
                    "type": "string",
                    "description": "Field that caused error"
                }
            },
            "additionalProperties": true
        }
    },
    "additionalProperties": true
}